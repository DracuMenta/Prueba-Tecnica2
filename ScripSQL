create procedure obtener_info_libro(ISBN_reg varchar(13))
	begin
		if exists (select 1 from Libro where Codigo_ISBN = ISBN_reg) then
			select L.*, A.nombre
			from Libro L
			inner join Autor A
			on L.ID_Autor = A.ID_Autor
			where L.Codigo_ISBN = ISBN_reg;	
		else
			signal sqlstate '45000' 
        	set message_text = 'El libro consultado no existe';
		end if;
	end
//

//
create function disponibilidad(ISBN_reg varchar(13))
	returns varchar(100)
	
	begin
		declare Usuario nvarchar(60);
		declare message nvarchar(100); 
		if exists (select 1 from controlprestamos where isbn = isbn_reg and dia_devolucion is null) then
	        select U.nombre into Usuario
	        from controlprestamos P
	        inner join libro L on P.ISBN = L.Codigo_ISBN
	        inner join Usuario U on P.id_usuario = U.id_usuario
	        where P.ISBN = ISBN_reg and P.Dia_Devolucion is null
	        limit 1;
	        
	        set message = concat('El usuario: ', Usuario, ' tiene el libro en uso');
	        return message;
	        
	    elseif not exists (select 1 from Libro where Codigo_ISBN = ISBN_reg) then
	        set message = 'El libro no existe';
	        return message;
	        
	    else
	        set message = 'El libro esta disponible';
	        return message;
	    end if;
	end
