//
create procedure historial_prestamos()
	begin
		select P.ID, U.Nombre, L.Titulo, P.Dia_Prestamos, P.Dia_Devolucion, P.Observacion
		from ControlPrestamos P
		inner join Libro L
		on P.ISBN = L.Codigo_ISBN
		inner join Usuario U
		on P.ID_Usuario = U.ID_Usuario
		where Dia_Devolucion is not null;
	end
//

//
create procedure cambio_estado(id_reg varchar(10))
	begin
		if exists (select 1 from Usuario where Estado = 'Activo' and ID_Usuario = id_reg) then
			update Usuario
			set Estado = 'Deshabilitado' 
			where ID_Usuario = id_reg;
		else
			update Usuario
			set Estado = 'Activo'
			where ID_Usuario = id_reg;
		end if;
	end
//

//
create procedure estado_usuarios()
	begin
		select Estado, ID_Usuario, Nombre from Usuario; 
	end
//

//
create function prestamos_usuario(id_usuario_reg varchar(10))
	returns int
	
	begin
		declare Cantidad int;
	
		select count(*)
		into Cantidad
		from ControlPrestamos 
		where ID_Usuario = id_usuario_reg and Dia_Devolucion is null;
	
		return Cantidad;
	end
